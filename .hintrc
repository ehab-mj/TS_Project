{
  "extends": [
    "development"
  ],
  "hints": {
    "compat-api/css": [
      "default",
      {
        "ignore": [
          "backdrop-filter",
          "min-width: fit-content"
        ]
      }
    ],
    "typescript-config/is-valid": "off",
    "typescript-config/consistent-casing": "off",
    "axe/keyboard": [
      "default",
      {
        "nested-interactive": "off"
      }
    ]
  }
}